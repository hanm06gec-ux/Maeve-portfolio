# Callback to update chart based on slider range
@app.callback(
    Output('pricing-bar-chart', 'figure'),
    Input('money-range-slider', 'value')  # Input from the slider
)
def update_chart(selected_range):
    # Filter data within the selected range
    filtered_df = df[
        (df['discount_price__amount'] >= selected_range[0]) &
        (df['discount_price__amount'] <= selected_range[1])
    ]
    
    # Dynamically create 5 bins within the selected range
    bin_size = (selected_range[1] - selected_range[0]) / 10  # Ensure 5 bins
    bins = np.arange(selected_range[0], selected_range[1] + bin_size, bin_size)
    bin_labels = [f"${bins[i]:.2f}-${bins[i+1]:.2f}" for i in range(len(bins)-1)]
    
    filtered_df['Cluster'] = pd.cut(
        filtered_df['discount_price__amount'], bins=bins, labels=bin_labels, include_lowest=True
    )
    
    # Count the number of students in each bin
    cluster_counts = filtered_df['Cluster'].value_counts().sort_index()

    # Create the bar chart
    fig = px.bar(
        x=cluster_counts.index.astype(str),  # Convert bins to string for x-axis
        y=cluster_counts.values,
        labels={'x': 'Investment Range ($)', 'y': 'Number of Students'}, 
        color_discrete_map="#A65665"
    )
    
    # Add percentage labels to each bar
    fig.update_traces(
        color="#A65665",
        text=[f"{val:.1f}%" for val in (cluster_counts / cluster_counts.sum() * 100)],
        textposition='outside'  # Position labels outside the bars
    )
    return fig


