# Categorize the title based on the course name
def categorize_title(title):
    title_lower = title.lower()
    if 'personal finance' in title_lower or 'budgeting' in title_lower or 'saving' in title_lower or 'retirement' in title_lower:
        return 'Personal Finance'
    elif 'investment banking' in title_lower or 'investment bank' in title_lower:
        return 'Investment Banking'
    elif 'banking' in title_lower or 'loans' in title_lower or 'credit' in title_lower:
        return 'Banking'
    elif any(kw in title_lower for kw in ['agile', 'scrum', 'pmp', 'project management']):
        return 'Project Management'
    elif any(kw in title_lower for kw in ['cfa', 'chartered financial analyst']):
        return 'CFA (Chartered Financial Analyst)'
    elif 'financial analysis' in title_lower or 'analysis' in title_lower:
        return 'Financial Analysis'
    elif 'financial management' in title_lower or 'management finance' in title_lower:
        return 'Financial Management'
    elif 'technical analysis' in title_lower or 'stock market' in title_lower or 'charting' in title_lower:
        return 'Technical Analysis (Finance)'
    elif 'accounting' in title_lower or 'bookeeping' in title_lower or 'audit' in title_lower:
        return 'Accounting'
    elif any(kw in title_lower for kw in ['data science', 'analytics', 'machine learning']):
        return 'Data Science'
    elif 'management' in title_lower:
        return 'Management'
    elif 'leadership' in title_lower:
        return 'Leadership'
    elif 'communication' in title_lower:
        return 'Communication'
    else:
        return 'Other'


